NODE_ENV=production

# Public URL of the wiki
URL=https://members.brassliberation.org
PORT=3000

# Generate with: openssl rand -hex 32
SECRET_KEY=
UTILS_SECRET=

# Postgres — matches docker-compose.yml credentials
DATABASE_URL=postgres://user:pass@postgres:5432/outline
DATABASE_CONNECTION_POOL_MIN=0
DATABASE_CONNECTION_POOL_MAX=5
PGSSLMODE=disable

# Redis
REDIS_URL=redis://redis:6379

# Local file storage (persisted via Docker volume)
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=26214400

# https-portal handles SSL, so Outline itself runs plain HTTP
FORCE_HTTPS=false

# Logto OIDC — create a Traditional Web App in Logto for Outline
# Redirect URI:             https://members.brassliberation.org/auth/oidc.callback
# Post-logout redirect URI: https://members.brassliberation.org
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTH_URI=https://auth.members.brassliberation.org/oidc/auth
OIDC_TOKEN_URI=https://auth.members.brassliberation.org/oidc/token
OIDC_USERINFO_URI=https://auth.members.brassliberation.org/oidc/me
OIDC_LOGOUT_URI=https://auth.members.brassliberation.org/oidc/session/end
OIDC_USERNAME_CLAIM=email
OIDC_DISPLAY_NAME=Logto
OIDC_DISABLE_REDIRECT=false
OIDC_SCOPES=openid profile email

DEFAULT_LANGUAGE=en_US
RATE_LIMITER_ENABLED=true
LOG_LEVEL=info
