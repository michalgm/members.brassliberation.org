# Traditional Web App registered in Logto for the invite tool's own OIDC login.
# Create it at https://auth-admin.members.brassliberation.org with:
#   Redirect URI:             https://invite.members.brassliberation.org/callback
#   Post-logout redirect URI: https://invite.members.brassliberation.org
LOGTO_ADMIN_CLIENT_ID=
LOGTO_ADMIN_CLIENT_SECRET=

# Machine-to-Machine app registered in Logto for calling the Logto management API.
# Grant it "all" permissions under the Logto Management API resource.
LOGTO_M2M_CLIENT_ID=
LOGTO_M2M_CLIENT_SECRET=

LOGTO_ENDPOINT=https://auth.members.brassliberation.org
LOGTO_ORG_ID=

# The Logto Application ID of the Outline wiki app (used to build magic-link URLs)
WIKI_APP_ID=

OUTLINE_URL=https://members.brassliberation.org
ADMIN_TOOL_URL=https://invite.members.brassliberation.org

# Generate with: openssl rand -hex 32
SESSION_SECRET=
